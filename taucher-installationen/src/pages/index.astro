---
import Base from '../layouts/Base.astro';
import content from '../../content.json';

const { site, contact, testimonials, faq, impressum } = content;

const services = [
  {
    title: 'Heizungsbau & Modernisierung',
    desc: 'Von der Planung bis zur Inbetriebnahme – wir installieren und modernisieren Heizsysteme aller Art. Effizient, zukunftssicher und auf Ihre Bedürfnisse zugeschnitten.',
    image: '/images/slider_2.jpg'
  },
  {
    title: 'Gas-, Öl- & Pelletsheizungen',
    desc: 'Fachgerechte Installation und Wartung von Gas-, Öl- und Pelletsheizungen. Wir beraten Sie zur optimalen Lösung für Ihre Immobilie.',
    image: '/images/slider_4.jpg'
  },
  {
    title: 'Wärmepumpen & Erneuerbare',
    desc: 'Zukunftssichere Heiztechnik: Wärmepumpen, Solarthermie und Hybridlösungen für maximale Energieeffizienz und Förderung.',
    image: '/images/slider_8.jpg'
  },
  {
    title: 'Sanitärinstallationen',
    desc: 'Komplette Rohrleitungsarbeiten, Wasserinstallationen und Montage hochwertiger Sanitärprodukte – sauber ausgeführt und schlüsselfertig.',
    image: '/images/slider_3.jpg'
  },
  {
    title: 'Badsanierung',
    desc: 'Ihr Traumbad in neuer Pracht: Wir planen und realisieren Ihre Badsanierung komplett – von der Fliese bis zur Armatur, alles aus einer Hand.',
    image: '/images/slider_3a.jpg'
  },
  {
    title: 'Wartung & Notdienst',
    desc: '24h-Notdienst bei Rohrbruch oder Heizungsausfall. Regelmäßige Wartung verlängert die Lebensdauer Ihrer Anlagen erheblich.',
    image: '/images/slider_5a.jpg'
  }
];

const mobileNoClean = contact.mobile.replace(/[\s\/]/g, '');
const phoneNoClean = contact.phone.replace(/[\s\/]/g, '');
---

<Base title={`${site.name} | Gas · Sanitär · Heizung – Wien/NÖ`}>

  <!-- ===== STICKY HEADER ===== -->
  <header class="site-header at-top" id="site-header">
    <div class="header-inner">
      <a href="#" class="nav-logo-link" aria-label="Taucher Installationen – Startseite">
        <div class="logo-chip">
          <img src="/images/logo.png" alt="Taucher Installationen GmbH" class="nav-logo" />
        </div>
      </a>

      <ul class="nav-links" role="list">
        <li><a href="#leistungen">Leistungen</a></li>
        <li><a href="#ueber-uns">Über uns</a></li>
        <li><a href="#galerie">Galerie</a></li>
        <li><a href="#ablauf">Ablauf</a></li>
        <li><a href="#bewertungen">Bewertungen</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
      </ul>

      <div class="nav-actions">
        <a href='#kontakt' class='btn btn-primary header-btn'>
          <svg width='16' height='16' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z'/>
          </svg>
          Jetzt anfragen
        </a>
        <a href='tel:+436642141285' class='btn btn-accent header-btn'>
          <svg width='16' height='16' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'>
            <path d='M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z'/>
          </svg>
          Jetzt anrufen
        </a>
      </div>

      <button class="mobile-toggle" id="mobile-toggle" aria-label="Menü" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav class="mobile-nav" id="mobile-nav" hidden aria-label="Mobilnavigation">
      <ul class="mobile-nav-links" role="list">
        <li><a href="#leistungen">Leistungen</a></li>
        <li><a href="#ueber-uns">Über uns</a></li>
        <li><a href="#galerie">Galerie</a></li>
        <li><a href="#ablauf">Ablauf</a></li>
        <li><a href="#bewertungen">Bewertungen</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
      </ul>
      <a href={`tel:${mobileNoClean}`} class="mobile-nav-notruf">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z'/></svg>
        Notruf: {contact.mobile}
      </a>
      <a href={`tel:${phoneNoClean}`} class="mobile-nav-phone">{contact.phone}</a>
    </nav>
  </header>

  <main id="main-content">

    <!-- ===== HERO SLIDESHOW ===== -->
    <section class="hero" aria-label="Willkommen bei Taucher Installationen">
      <div class="hero-slides" id="hero-slides">
        <div class="hero-slide active" style="background-image: url('/images/slider_home.jpg')"></div>
        <div class="hero-slide" style="background-image: url('/images/slider_2.jpg')"></div>
        <div class="hero-slide" style="background-image: url('/images/slider_7.jpg')"></div>
        <div class="hero-slide" style="background-image: url('/images/slider_4.jpg')"></div>
      </div>
      <div class="hero-overlay" aria-hidden="true"></div>

      <div class="container hero-container">
        <div class="hero-content">
          <span class="hero-badge">
            <span class="hero-badge-dot" aria-hidden="true"></span>
            Ihr Experte für Heizung &amp; Sanitär
          </span>
          <h1>
            Gas · Sanitär · Heizung
          </h1>
          <p class="hero-sub">
            Ihr verlässlicher Partner im Südburgenland
          </p>
          <div class="hero-ctas">
            <a href="#kontakt" class="btn btn-primary btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Kostenlos anfragen
            </a>
            <a href={`tel:${mobileNoClean}`} class="btn btn-outline-white btn-lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              {contact.mobile}
            </a>
          </div>
        </div>
      </div>

      <div class="hero-scroll" aria-hidden="true">
        <div class="hero-scroll-line"></div>
        <span>Scroll</span>
      </div>
      <div class="hero-dots" id="hero-dots" role="tablist" aria-label="Slideshow Navigation"></div>
    </section>

    <!-- ===== TRUST BAR ===== -->
    <div class="trust-bar" role="list" aria-label="Unsere Qualitätsmerkmale">
      <div class="container trust-bar-inner">
        <div class="trust-item" role="listitem">
          <div class="trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="#1B3A6B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div>
            <strong>25+ Jahre</strong>
            <span class="trust-label">Erfahrung im Handwerk</span>
          </div>
        </div>
        <div class="trust-item" role="listitem">
          <div class="trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="#1B3A6B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div>
            <strong>24h Notdienst</strong>
            <span class="trust-label">Immer für Sie erreichbar</span>
          </div>
        </div>
        <div class="trust-item" role="listitem">
          <div class="trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="#1B3A6B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div>
            <strong>WK zertifiziert</strong>
            <span class="trust-label">Geprüfte Qualität</span>
          </div>
        </div>
        <div class="trust-item" role="listitem">
          <div class="trust-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="#1B3A6B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div>
            <strong>Kostenlose Beratung</strong>
            <span class="trust-label">Unverbindlich &amp; persönlich</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== ÜBER TAUCHER INSTALLATIONEN ===== -->
    <section id="ueber-uns" class="about-section" aria-labelledby="about-h">
      <div class="container">
        <div class="about-grid">
          <div class="about-content anim-ready anim-slide-left">
            <span class="section-label">Seit über 25 Jahren</span>
            <h2 id="about-h">Taucher Installationen GmbH</h2>
            <p>Wir sind Ihr zuverlässiger Partner für Gas-, Sanitär- und Heizungsinstallationen in Wien und Niederösterreich. Seit über 25 Jahren steht unser Name für Qualität, Verlässlichkeit und professionelle Handwerksarbeit.</p>
            <ul class="check-list">
              <li>Meisterbetrieb mit über 25 Jahren Erfahrung</li>
              <li>Zertifizierter Fachbetrieb</li>
              <li>Über 2.500 zufriedene Kunden</li>
              <li>24-Stunden-Notdienst</li>
            </ul>
          </div>
          <div class="about-slideshow" id="about-slides-container" aria-label="Eindrücke aus unserem Betrieb">
            <div class="about-slide active" style="background-image: url('/images/firmengebaude.png')"></div>
            <div class="about-slide" style="background-image: url('/images/slider_home.jpg')"></div>
            <div class="about-slide" style="background-image: url('/images/service.png')"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== LEISTUNGEN ===== -->
    <section id="leistungen" class="leistungen" aria-labelledby="leistungen-h">
      <div class="container">
        <header class="section-head anim-ready anim-fade-up">
          <span class="section-tag">Unsere Dienstleistungen</span>
          <h2 id="leistungen-h">Alles rund um Heizung,<br>Sanitär &amp; Gas</h2>
          <p>Von der Planung über die Installation bis zur laufenden Wartung – alle Leistungen aus einer Hand, für Privat und Gewerbe.</p>
        </header>

        <div class="leistungen-grid">
          {services.map((s, i) => (
            <article class={`leistung-card anim-ready anim-fade-up delay-${i + 1}`}>
              <div class="leistung-img-wrap">
                <img src={s.image} alt={s.title} class="leistung-img" loading="lazy" decoding="async" />
              </div>
              <div class="leistung-body">
                <h3>{s.title}</h3>
                <p>{s.desc}</p>
                <a href="#kontakt" class="leistung-link" aria-label={`Mehr zu ${s.title}`}>
                  Anfrage stellen
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== USP / TRUST SECTION ===== -->

    <!-- ===== CTA BANNER ===== -->
    <section class="cta-banner" aria-label="Jetzt Termin vereinbaren">
      <div class="container cta-banner-inner">
        <div class="cta-banner-text">
          <h2>Kostenlos beraten lassen</h2>
          <p>Kein Projekt zu groß, kein Problem zu klein. Jetzt unverbindlichen Termin anfragen.</p>
        </div>
        <div class="cta-banner-btns">
          <a href="#kontakt" class="btn btn-white btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Formular ausfüllen
          </a>
          <a href={`tel:${phoneNoClean}`} class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            Jetzt anrufen
          </a>
        </div>
      </div>
    </section>

    <!-- ===== GALERIE ===== -->
    <section id="galerie" class="gallery-section" aria-labelledby="galerie-h">
      <div class="container">
        <div class="section-header anim-ready anim-fade-up">
          <span class="section-tag">Einblicke</span>
          <h2 id="galerie-h">Unsere Arbeit</h2>
          <p>Einblicke in unsere Projekte und unsere Arbeit</p>
        </div>
        <div class="gallery-grid">
          <div class="gallery-item anim-ready anim-fade-up delay-1">
            <img src="/images/slider_2.jpg" alt="Heizungsinstallation" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item anim-ready anim-fade-up delay-2">
            <img src="/images/slider_2a.jpg" alt="Sanitärarbeiten" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item anim-ready anim-fade-up delay-3">
            <img src="/images/slider_3.jpg" alt="Rohrleitungen" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item anim-ready anim-fade-up delay-4">
            <img src="/images/slider_4.jpg" alt="Heizungsanlage" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item anim-ready anim-fade-up delay-5">
            <img src="/images/slider_7.jpg" alt="Fachgerechte Montage" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-item anim-ready anim-fade-up delay-6">
            <img src="/images/slider_8.jpg" alt="Moderne Technik" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ABLAUF / PROCESS ===== -->
    <section id="ablauf" class="process" aria-labelledby="ablauf-h">
      <div class="container">
        <header class="section-head anim-ready anim-fade-up">
          <span class="section-tag">So funktioniert's</span>
          <h2 id="ablauf-h">Ihr Projekt in 4 einfachen Schritten</h2>
          <p>Unkompliziert, transparent und termingerecht – von der ersten Anfrage bis zur fertigen Installation.</p>
        </header>

        <div class="process-steps">
          <div class="process-step anim-ready anim-fade-up delay-1">
            <div class="process-step-num" aria-hidden="true">1</div>
            <h3>Kontaktaufnahme</h3>
            <p>Rufen Sie uns an oder senden Sie uns eine Anfrage. Kostenlos und vollständig unverbindlich.</p>
          </div>
          <div class="process-step anim-ready anim-fade-up delay-2">
            <div class="process-step-num" aria-hidden="true">2</div>
            <h3>Beratung &amp; Angebot</h3>
            <p>Wir besichtigen Ihr Objekt vor Ort und erstellen ein transparentes Angebot.</p>
          </div>
          <div class="process-step anim-ready anim-fade-up delay-3">
            <div class="process-step-num" aria-hidden="true">3</div>
            <h3>Fachgerechte Ausführung</h3>
            <p>Unser Team führt alle Arbeiten professionell, sauber und termingerecht durch.</p>
          </div>
          <div class="process-step anim-ready anim-fade-up delay-4">
            <div class="process-step-num" aria-hidden="true">4</div>
            <h3>Übergabe &amp; Service</h3>
            <p>Wir übergeben das fertige Projekt und bleiben als zuverlässiger Wartungspartner an Ihrer Seite.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TESTIMONIALS ===== -->
    <section id="bewertungen" class="testimonials" aria-labelledby="bewertungen-h">
      <div class="container">
        <header class="section-head anim-ready anim-fade-up">
          <span class="section-tag">Kundenstimmen</span>
          <h2 id="bewertungen-h">Was unsere Kunden sagen</h2>
          <p>Zufriedene Kunden sind unsere beste Referenz — seit über 25 Jahren.</p>
        </header>

        <div class="testimonials-grid">
          {testimonials.items.map((t, i) => (
            <blockquote class={`testimonial-card anim-ready anim-fade-up delay-${i + 1}`}>
              <div class="testimonial-stars" aria-label="5 von 5 Sternen">★★★★★</div>
              <p class="testimonial-text">{t.text}</p>
              <footer class="testimonial-author">
                <div class="testimonial-avatar" aria-hidden="true">{t.name.charAt(0)}</div>
                <div>
                  <div class="testimonial-name">{t.name}</div>
                  <div class="testimonial-loc">Zufriedener Kunde</div>
                </div>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section id="faq" class="faq" aria-labelledby="faq-h">
      <div class="container">
        <header class="section-head anim-ready anim-fade-up">
          <span class="section-tag">Häufige Fragen</span>
          <h2 id="faq-h">Antworten auf Ihre Fragen</h2>
          <p>Alles Wichtige auf einen Blick – und falls etwas offen bleibt, rufen Sie uns einfach an.</p>
        </header>

        <div class="faq-list">
          {faq.items.map((item) => (
            <details class="faq-item anim-ready anim-fade-up">
              <summary>{item.q}</summary>
              <div class="faq-answer"><p>{item.a}</p></div>
            </details>
          ))}
        </div>

        <div class="faq-cta">
          <p>Noch Fragen? Wir helfen Ihnen gerne persönlich weiter.</p>
          <a href={`tel:${phoneNoClean}`} class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            {contact.phone}
          </a>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT ===== -->
    <section id="kontakt" class="contact" aria-labelledby="kontakt-h">
      <div class="container">
        <header class="section-head anim-ready anim-fade-up">
          <span class="section-tag">Kontakt</span>
          <h2 id="kontakt-h">Sprechen Sie uns an</h2>
          <p>Kostenlose Erstberatung, unverbindliches Angebot – wir melden uns innerhalb von 24 Stunden.</p>
        </header>

        <div class="contact-grid">
          <!-- Infos -->
          <div>
            <h3 class="contact-info-title">Kontaktdaten</h3>
            <p class="contact-intro">Wir sind Ihr verlässlicher Partner für alle Fragen rund um Heizung, Sanitär und Gas. Rufen Sie uns an oder schreiben Sie uns.</p>

            <div class="contact-details">
              <div class="contact-item">
                <div class="contact-icon" aria-hidden="true">📞</div>
                <div>
                  <span class="contact-item-label">Telefon</span>
                  <a href={`tel:${phoneNoClean}`} class="contact-item-value">{contact.phone}</a>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon" aria-hidden="true">📱</div>
                <div>
                  <span class="contact-item-label">Mobil / Notdienst 24h</span>
                  <a href={`tel:${mobileNoClean}`} class="contact-item-value">{contact.mobile}</a>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon" aria-hidden="true">✉️</div>
                <div>
                  <span class="contact-item-label">E-Mail</span>
                  <a href={`mailto:${contact.email}`} class="contact-item-value">{contact.email}</a>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon" aria-hidden="true">📍</div>
                <div>
                  <span class="contact-item-label">Adresse</span>
                  <a
                    href={`https://maps.google.com/?q=${encodeURIComponent(contact.address)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="contact-item-value"
                  >{contact.address}</a>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon" aria-hidden="true">🕐</div>
                <div>
                  <span class="contact-item-label">Öffnungszeiten</span>
                  <div class="contact-hours-list">
                    {contact.hours.map((h) => (
                      <span>{h.label}: <strong>{h.time}</strong></span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Formular -->
          <div class="contact-form-card anim-ready anim-fade-up">
            <h3 class="contact-form-title">Kostenlose Anfrage senden</h3>
            <form id="contact-form" action="#" method="POST" novalidate aria-label="Kontaktformular">
              <div class="form-row">
                <div class="form-group">
                  <label for="fname">Name *</label>
                  <input type="text" id="fname" name="name" placeholder="Max Mustermann" required autocomplete="name" />
                </div>
                <div class="form-group">
                  <label for="fphone">Telefon</label>
                  <input type="tel" id="fphone" name="phone" placeholder="0664 ..." autocomplete="tel" />
                </div>
              </div>
              <div class="form-group">
                <label for="femail">E-Mail *</label>
                <input type="email" id="femail" name="email" placeholder="max@beispiel.at" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="fsubject">Betreff</label>
                <select id="fsubject" name="subject">
                  <option value="">Bitte auswählen...</option>
                  <option>Heizungsbau / Modernisierung</option>
