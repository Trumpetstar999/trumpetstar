---
import '../styles/global.css';
import content from '../../content.json';

const { site, meta, footer, impressum } = content;
---

<!DOCTYPE html>
<html lang={site.lang || 'de'}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{meta.title}</title>
  <meta name="description" content={meta.description}>
  <meta property="og:title" content={meta.title}>
  <meta property="og:description" content={meta.description}>
  <meta property="og:type" content="website">
  <meta property="og:image" content={meta.ogImage}>
  <link rel="canonical" href={meta.canonical}>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏠</text></svg>">
  
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Wohnmode Gibiser",
    "description": "Raumausstatter, Bodenleger & Tapezierer im Südburgenland seit 1904",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Obere Hauptstraße 14",
      "addressLocality": "Heiligenkreuz im Lafnitztal",
      "postalCode": "7561",
      "addressCountry": "AT"
    },
    "url": "{meta.canonical}"
  }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-to-main">Zum Hauptinhalt springen</a>
  
  <slot />

  <!-- ===== FOOTER ===== -->
  <footer class="site-footer">
    <div class="footer-inner container">
      <img src="/images/logo-small.jpg" alt={site.name} class="footer-logo" width="100" height="40" />
      
      <div class="footer-social">
        {footer.social?.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label}>
            {link.icon === 'facebook' && <span>📘</span>}
            {link.icon === 'instagram' && <span>📷</span>}
          </a>
        ))}
      </div>
      
      <p class="footer-copyright">{footer.copyright}</p>
      
      <ul class="footer-links" role="list">
        {footer.links.map((link) => (
          <li><a href={link.href}>{link.text}</a></li>
        ))}
      </ul>
    </div>
    
    <div class="footer-credit">
      <span>Website by</span>
      <a href="https://openclaw.io" target="_blank" rel="noopener">
        <img src="/images/openclaw-logo.svg" alt="OpenClaw" class="footer-credit-logo" width="80" height="28" />
      </a>
    </div>
  </footer>

  <!-- ===== IMPRESSUM MODAL ===== -->
  <div id="impressum" class="legal-modal" aria-hidden="true">
    <div class="legal-modal__overlay" onclick="closeLegalModal('impressum')"></div>
    <div class="legal-modal__content" role="dialog" aria-modal="true" aria-labelledby="impressum-title">
      <button class="legal-modal__close" onclick="closeLegalModal('impressum')" aria-label="Schließen">×</button>
      <h2 id="impressum-title">{impressum.title}</h2>
      {impressum.lines.map((line) => (
        <p>{line || <br />}</p>
      ))}
    </div>
  </div>

  <!-- ===== DATENSCHUTZ MODAL ===== -->
  <div id="datenschutz" class="legal-modal" aria-hidden="true">
    <div class="legal-modal__overlay" onclick="closeLegalModal('datenschutz')"></div>
    <div class="legal-modal__content" role="dialog" aria-modal="true" aria-labelledby="datenschutz-title">
      <button class="legal-modal__close" onclick="closeLegalModal('datenschutz')" aria-label="Schließen">×</button>
      <h2 id="datenschutz-title">Datenschutzerklärung</h2>
      <p><strong>Verantwortlicher:</strong><br />{site.name}<br />{content.contact.address}</p>
      <h3>Datenschutz</h3>
      <p>Die Betreiber dieser Seiten nehmen den Schutz Ihrer persönlichen Daten sehr ernst. Wir behandeln Ihre personenbezogenen Daten vertraulich und entsprechend der gesetzlichen Datenschutzvorschriften sowie dieser Datenschutzerklärung.</p>
      <h3>Kontaktformular</h3>
      <p>Wenn Sie uns per Kontaktformular Anfragen zukommen lassen, werden Ihre Angaben aus dem Anfrageformular inklusive der von Ihnen dort angegebenen Kontaktdaten zwecks Bearbeitung der Anfrage und für den Fall von Anschlussfragen bei uns gespeichert. Diese Daten geben wir nicht ohne Ihre Einwilligung weiter.</p>
      <h3>Recht auf Auskunft, Löschung, Sperrung</h3>
      <p>Sie haben jederzeit das Recht auf unentgeltliche Auskunft über Ihre gespeicherten personenbezogenen Daten, deren Herkunft und Empfänger und den Zweck der Datenverarbeitung sowie ein Recht auf Berichtigung, Sperrung oder Löschung dieser Daten.</p>
    </div>
  </div>

  <script>
    // Legal modal functions
    function openLegalModal(id) {
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeLegalModal(id) {
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    }

    // Handle legal links
    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href === '#impressum' || href === '#datenschutz') {
          e.preventDefault();
          openLegalModal(href.substring(1));
        }
      });
    });

    // Close modal on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.legal-modal.is-open').forEach(modal => {
          closeLegalModal(modal.id);
        });
      }
    });

    // Navbar scroll effect
    (function() {
      const nav = document.querySelector('.site-nav');
      if (!nav) return;
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      }, { passive: true });
    })();

    // Intersection Observer for animations
    (function() {
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('anim-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.anim-ready').forEach(el => {
        observer.observe(el);
      });
    })();
  </script>

  <style>
    /* Legal Modal Styles */
    .legal-modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .legal-modal.is-open {
      display: flex;
    }

    .legal-modal__overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
    }

    .legal-modal__content {
      position: relative;
      background: var(--bg-white);
      max-width: 700px;
      max-height: 80vh;
      overflow-y: auto;
      padding: 2.5rem;
      box-shadow: var(--shadow-md);
      z-index: 1;
    }

    .legal-modal__content h2 {
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }

    .legal-modal__content h3 {
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      font-size: 1.1rem;
    }

    .legal-modal__content p {
      margin-bottom: 1rem;
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .legal-modal__close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--charcoal);
    }

    .legal-modal__close:hover {
      color: var(--orange);
    }
  </style>
</body>
</html>
